# ─────────────────────────────────────────────────────────────
# KOSTIFY - Environment Variables
# Salin file ini menjadi .env lalu isi nilainya
# JANGAN commit file .env ke GitHub!
# ─────────────────────────────────────────────────────────────

# Supabase (wajib)
# Ambil dari: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Midtrans (isi setelah daftar di midtrans.com)
# Ambil dari: Midtrans Dashboard → Settings → Access Keys
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
VITE_MIDTRANS_PRODUCTION=false
